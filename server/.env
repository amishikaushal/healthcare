# Server Environment Variables
NODE_ENV=development
PORT=5001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recoveryos
DB_USER=postgres
DB_PASSWORD=Amishi@14
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_EMAIL_SECRET=change_me_email_secret
JWT_RESET_SECRET=change_me_reset_secret

# BCrypt
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

GEMINI_API_KEY=AIzaSyBeQd1GCDGL2YaihBzWiB0mxAn3crI7NLs

GEMINI_MODEL=gemini-2.5-flash

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
