# ─────────────────────────────────────────────────────────────────────────────
# RecoveryOS — Server Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5001

# ── Database ──────────────────────────────────────────────────────────────────
# PRODUCTION (Neon): Set DATABASE_URL — overrides all DB_* vars below.
# Neon Console → Project → Connection Details → Connection string
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# LOCAL / DOCKER: Use individual vars below.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recoveryos
DB_USER=postgres
DB_PASSWORD=your_database_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_EMAIL_SECRET=change_me_email_secret
JWT_RESET_SECRET=change_me_reset_secret

# ── BCrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# LOCAL: allow Vite dev server ports
# PRODUCTION: set to your Vercel URL (no trailing slash)
# Example: https://recoveryos.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=50

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
# LOCAL: Docker container URL
# PRODUCTION: Qdrant Cloud — https://cloud.qdrant.io (free tier available)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=recoveryos_docs

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@recoveryos.com

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB=10
